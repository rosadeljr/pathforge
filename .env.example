# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# AI Provider
AI_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key
# ANTHROPIC_API_KEY=your_anthropic_api_key

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=PathForge <onboarding@your-verified-domain.com>

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Payments (PayMongo — automated GCash + Maya)
PAYMONGO_SECRET_KEY=sk_test_your_paymongo_secret_key
PAYMONGO_WEBHOOK_SECRET=whsec_your_paymongo_webhook_secret

# Cron jobs (Vercel)
CRON_SECRET=any_long_random_string
